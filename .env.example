# Caminho para a pasta do mês (ex: C:\Documentos\2026\02 - FEVEREIRO)
PATH_FOLDER='exemplo/relatorios/2026/01 - JANEIRO'

# Caminho para a planilha de e-mails
LISTA_EMAILS='exemplo/lista_emails_exemplo.xlsx'

# Credenciais de e-mail
SENDER_EMAIL='remetente@empresa.com'
LOGIN_EMAIL='login@empresa.com'
LOGIN_PASSWORD='sua_senha_ou_app_password'

# Destinatários em cópia (separados por ;)
CC_EMAILS='copia1@empresa.com;copia2@empresa.com'

# Servidor SMTP (padrão: Office 365)
SMTP_SERVER='smtp.office365.com'
SMTP_PORT=587

# Corpo do e-mail (suporta HTML)
BODY_MESSAGE='<p>Olá, tudo bem?</p><p>Segue em anexo o relatório financeiro referente ao período.</p><p>Att.,<br>Equipe Financeira</p>'
